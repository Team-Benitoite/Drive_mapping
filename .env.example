# ----------------------------------------------------------------
# バックエンド選択（既定: local）
#   local    … localStorage に保存。外部サービス不要でそのまま動く。
#   supabase … Supabase を使用（下の URL / anon キーが必須）。
# ----------------------------------------------------------------
VITE_BACKEND=local

# Supabase を使う場合のみ設定（VITE_BACKEND=supabase のとき）。
# Supabase ダッシュボード > Project Settings > API から取得。
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
